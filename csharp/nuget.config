<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Committed value is a repo-root-relative marker. CI rewrites this line
         to an absolute path via a sed step before dotnet restore:
           <add key="bifrost-contracts" value="${{ github.workspace }}/packages" />
         so NuGet resolves regardless of the csproj's nesting depth.
         See bifrost-algo/.github/workflows/ci.yml contracts-smoke-csharp job. -->
    <add key="bifrost-contracts" value="./packages" />
  </packageSources>
</configuration>
